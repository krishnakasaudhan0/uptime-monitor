<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Uptime</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background-color: #0f172a; /* Slate-900 */
        }
    </style>
</head>
<body class="min-h-screen text-slate-100 antialiased p-8">
    <div class="max-w-4xl mx-auto bg-slate-800/50 backdrop-blur-xl border border-slate-700/50 rounded-2xl p-10 shadow-2xl">
        
        <div class="flex justify-between items-center mb-8 pb-6 border-b border-slate-700">
            <div>
                <h1 class="text-3xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-500">Dashboard</h1>
                <p class="text-slate-400 text-sm mt-1">Welcome back, <%= user.name %>!</p>
            </div>
            
            <a href="/users/logout" class="bg-red-500/10 text-red-400 hover:bg-red-500/20 px-5 py-2.5 rounded-lg text-sm font-semibold transition-colors border border-red-500/20">
                Log Out
            </a>
        </div>

        <% if (success && success.length > 0) { %>
            <div class="bg-green-500/10 border border-green-500/50 text-green-400 px-4 py-3 rounded-lg mb-8 text-sm">
                <%= success %>
            </div>
        <% } %>

        <div class="bg-slate-900/50 rounded-xl p-6 border border-slate-700">
            <div class="flex items-center gap-6">
                <% if (user.avatar) { %>
                    <img src="<%= user.avatar %>" alt="Profile avatar" class="w-20 h-20 rounded-full border border-slate-600 shadow-md">
                <% } else { %>
                    <div class="w-20 h-20 rounded-full bg-gradient-to-tr from-blue-500 to-purple-500 flex items-center justify-center text-2xl font-bold shadow-md">
                        <%= user.name.charAt(0).toUpperCase() %>
                    </div>
                <% } %>
                
                <div>
                    <h2 class="text-xl font-semibold"><%= user.name %></h2>
                    <p class="text-slate-400"><%= user.email %></p>
                    <div class="mt-2 inline-block px-3 py-1 rounded-full text-xs font-medium bg-blue-500/10 text-blue-400 border border-blue-500/20">
                        Auth Provider: <%= user.authProvider || 'Local' %>
                    </div>
                </div>
            </div>
            
            <p class="mt-8 text-slate-400 text-sm leading-relaxed">
                You have successfully reached the protected <strong>/</strong> route because your session token is active!
                Your session is configured to last exactly 1 day.
            </p>
        </div>
        
    </div>
</body>
</html>
